{
  "hosting": {
    "site": "beinganujchaudhary",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/projects/aetherRead/app/reader/**",
        "destination": "/projects/aetherRead/app/reader/_placeholder/index.html"
      }
    ],
    "redirects": [
      {
        "source": "/projects/aetherRead",
        "destination": "/projects/aetherRead/",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "/projects/aetherRead/_next/static/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
